generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id              Int           @id @default(1)
  fullName        String
  nickname        String
  headline        String
  subheadline     String
  summary         String
  email           String
  phone           String
  location        String
  availability    String
  resumeFocus     String
  yearsExperience String
  projectCount    String
  currentRole     String
  expectedSalary  String
  startWindow     String
  avatarPath      String
  primaryColor    String
  secondaryColor  String
  personalDetails Json
  highlightItems  Json
  skillGroups     Json
  languages       Json
  strengths       Json
  typingSpeed     String
  transport       String
  socials         Json
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  experiences     Experience[]
  projects        Project[]
  educations      Education[]
  certificates    Certificate[]
}

model Experience {
  id        Int      @id @default(autoincrement())
  profileId Int
  period    String
  company   String
  position  String
  location  String
  salary    String?
  highlights Json
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Project {
  id          Int      @id @default(autoincrement())
  profileId   Int
  name        String
  category    String
  stack       String
  summary     String   @db.Text
  impact      String   @db.Text
  link        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Education {
  id        Int      @id @default(autoincrement())
  profileId Int
  period    String
  school    String
  degree    String
  major     String?
  faculty   String?
  gpa       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Certificate {
  id        Int      @id @default(autoincrement())
  profileId Int
  period    String
  issuer    String
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
}
